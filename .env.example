# ─── Supabase PostgreSQL Connection ───────────────────────────
# Get these from: Supabase Dashboard → Settings → Database → Connection String

# Transaction pooler (port 6543) — used by the Next.js app at runtime
DATABASE_URL="postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-1-ap-south-1.pooler.supabase.com:6543/postgres"

# Session pooler (port 5432) — used by Prisma migrate deploy (needs PREPARE support)
DIRECT_URL="postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-1-ap-south-1.pooler.supabase.com:5432/postgres"
