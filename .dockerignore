# ─── Dependencies ─────────────────────────────────────────────
node_modules
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ─── Next.js build output ─────────────────────────────────────
.next
out
build
dist

# ─── Environment & secrets (NEVER bake into image) ────────────
.env
.env.local
.env.*.local
.env.development
.env.test
.env.production

# ─── Prisma generated (regenerated at build time) ─────────────
# Keep schema.prisma and migrations, skip generated client
node_modules/.prisma

# ─── Version control ──────────────────────────────────────────
.git
.gitignore
.gitattributes

# ─── Logs ─────────────────────────────────────────────────────
*.log
logs/
coverage/
.nyc_output

# ─── OS files ─────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ─── IDE & editor ─────────────────────────────────────────────
.vscode
.idea
*.swp
*.swo
*.suo

# ─── Testing ──────────────────────────────────────────────────
__tests__
*.test.ts
*.spec.ts
coverage
.jest

# ─── TypeScript ───────────────────────────────────────────────
*.tsbuildinfo

# ─── Misc ─────────────────────────────────────────────────────
.vercel
*.md
README*
docker-compose*.yml
Dockerfile*
docker-entrypoint.sh
postman/
